# =============================================================================
# Jobrolo — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# App / URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Database
# Production/external beta: managed Postgres is required. SQLite is dev-only and kept only as legacy reference.
DATABASE_URL=postgresql://user:password@host:5432/jobrolo
# Legacy local-only SQLite example: file:./db/custom.db

# SECURITY — REQUIRED in production
# Generate with: openssl rand -hex 32
SESSION_SECRET=
# Generate with: openssl rand -hex 32
CRON_SECRET=

# AI Provider
# z-ai = built-in SDK (rate-limited)
# openai-compatible = OpenAI, Azure, APILayer, Ollama, etc.
LLM_PROVIDER=z-ai
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_LAYER_SUBSCRIPTION_KEY=

# OCR Providers
# OCR_PROVIDER=none
# OCR_PROVIDER=apilayer_ocr
# APILAYER_OCR_API_KEY=

# Storage
# local = files in storage/private/uploads/ (dev or persistent-disk deployments only)
# s3 = AWS S3, Cloudflare R2, MinIO (recommended for serverless production)
STORAGE_PROVIDER=local
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=  # For R2/MinIO

# Communications / Notifications
# Outbound email/SMS stays queued/skipped unless this is true in production.
COMMUNICATIONS_ENABLED=false
NOTIFICATIONS_EMAIL_DEFAULT=false
NOTIFICATIONS_SMS_DEFAULT=false
NOTIFICATIONS_SEND_IMMEDIATELY=false

# Email providers: console, resend, sendgrid, postmark
EMAIL_PROVIDER=console
EMAIL_FROM=Jobrolo <notifications@example.com>
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# POSTMARK_SERVER_TOKEN=

# SMS provider: console, twilio
SMS_PROVIDER=console
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Password reset email provider can share EMAIL_PROVIDER settings.
RESET_EMAIL_PROVIDER=console

# Rate limiting / worker coordination
RATE_LIMIT_ENABLED=true
# Strongly recommended for production rate limits and job coordination.
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Production: set false and run npm run worker:loop or external cron for /api/cron?workflow=agent_jobs
AGENT_JOBS_INLINE=false
AGENT_JOB_WORKER_BATCH_SIZE=5

# Feature flags
JOBROLO_DEMO=0

# Active property research / street game planner
# Leave disabled until you connect a property-data provider/webhook.
PROPERTY_RESEARCH_ENABLED=0
# PROPERTY_RESEARCH_WEBHOOK_URL=https://your-property-provider.example.com/research
# PROPERTY_RESEARCH_API_KEY=
