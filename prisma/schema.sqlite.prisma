  selectedRcv   Float   @default(0)
  selectedAcv   Float   @default(0)
  excludedRcv   Float   @default(0)
  excludedAcv   Float   @default(0)
  // Deductible pool tracking
  remainingOutOfPocket Float?
  // Line items with selection state — JSON array
  lineItemsJson String  @default("[]")
  // Summary
  status        String  @default("pending") // pending, in_progress, finalized
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  document      Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  @@index([contractorId, documentId])
  @@index([documentId])
}

// --- Operations Radar (Insights) -------------------------------------------

model Insight {
  id            String   @id @default(cuid())
  contractorId  String
  type          String   // observation, risk, opportunity, recommendation, follow_up
  title         String
  detail        String
  confidence    Float    @default(0.7)
  source        String   // project, customer, document, claim, task, conversation
  sourceId      String?
  sourceName    String?
  // V3: Resolution tracking
  status        String   @default("active") // active, handled, needs_attention, needs_approval, waiting_customer, waiting_carrier, waiting_internal, resolved, dismissed
  resolutionDetail String?
  resolutionActions String? // JSON: ["Updated customer.email", "Created follow-up task cmq..."]
  // P0 proof fields — required for status=handled
  actionsTaken      String? // JSON: [{action: "db_update", table: "Customer", recordId: "...", field: "email", before: null, after: "x@y.com"}]
  recordsUpdated    String? // JSON: [{table: "Customer", id: "...", fields: ["email"]}]
  sourceIdsUsed     String? // JSON: ["doc_id_1", "doc_id_2"] — which docs were searched/used
  beforeValue       String? // JSON snapshot of what was missing
  afterValue        String? // JSON snapshot of what was set
  feedback      String?
  dedupKey      String
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
  dismissedAt   DateTime?
  updatedAt     DateTime @updatedAt
  contractor    Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@unique([contractorId, dedupKey])
  @@index([contractorId, status, type])
  @@index([contractorId, source, sourceId])
}




