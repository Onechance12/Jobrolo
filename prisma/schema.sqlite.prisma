// Jobrolo — AI Business Operating System for contractors
// Schema v2: 30+ models — auth, multi-tenant, layered memory, knowledge graph, agent jobs, audit, SaaS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contractor {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  logo      String?
  // SaaS / billing
  plan      String   @default("free") // free, pro, business, enterprise
  status    String   @default("active") // active, suspended, deleted
  trialEndsAt DateTime?
  // Soft delete
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customers      Customer[]
  projects       Project[]
  subcontractors Subcontractor[]
  suppliers      Supplier[]
  users          User[]
  estimates      Estimate[]
  documents      Document[]
  priceSheets    PriceSheet[]
  materialItems  MaterialItem[]
  workspaces     Workspace[]
  conversations  Conversation[]
  activities     ProjectActivity[]
  apiKeys        ApiKey[]
  auditLogs      AuditLog[]
  agentJobs      AgentJob[]
  agentLessons   AgentLesson[]
  customerMemories CustomerMemory[]
  projectMemories  ProjectMemory[]
  contractorMemories ContractorMemory[]
  conversationSummaries ConversationSummary[]
  entityRelations   EntityRelation[]
  cronRuns       CronRun[]
  usageRecords   UsageRecord[]
  onboardingSession OnboardingSession?
  insights      Insight[]
  profile       ContractorProfile?
}

model User {
  id              String   @id @default(cuid())
  contractorId    String
  name            String
  email           String   @unique
  phone           String?
  role            String   @default("manager") // owner, manager, sales, crew, accounting
  avatar          String?
  status          String   @default("active") // active, suspended, invited
  // Auth
  passwordHash    String?
  mfaSecret       String?
  mfaEnabled      Boolean  @default(false)
  lastLoginAt     DateTime?
  lastLoginIp     String?
  passwordResetToken String?
  passwordResetExpires DateTime?
  emailVerifiedAt DateTime?
  // SECURITY: tokenVersion for session invalidation — increment on password reset/role change
  tokenVersion     Int      @default(0)
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contractor       Contractor       @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  subContractorId  String?
  subcontractor    Subcontractor?   @relation(fields: [subContractorId], references: [id])
  uploadedDocs     Document[]       @relation("UploadedBy")
  workspaceMembers WorkspaceMember[]
  createdMemories  WorkspaceMemory[] @relation("MemoryCreator")
  createdMessages  WorkspaceMessage[] @relation("WorkspaceMessageCreator")
  auditLogs        AuditLog[]       @relation("AuditActor")
  apiKeys          ApiKey[]         @relation("ApiKeyOwner")
  @@index([contractorId, status])
}

model Customer {
  id           String   @id @default(cuid())
  contractorId String
  name         String
  email        String?
  phone        String?
  address      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contractor Contractor     @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  projects   Project[]
  estimates  Estimate[]
  documents  Document[]
  followUps  FollowUp[]
  noteRecords Note[]
  workspace  Workspace?
}

model Project {
  id           String    @id @default(cuid())
  contractorId String
  customerId   String?
  title        String
  status       String    @default("active")
  priority     String    @default("medium")
  address      String?
  value        Float?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  contractor    Contractor      @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  customer      Customer?       @relation(fields: [customerId], references: [id])
  tasks         Task[]
  notes         Note[]
  inspections   Inspection[]
  estimates     Estimate[]
  documents     Document[]
  quotes        Quote[]
  followUps     FollowUp[]
  workspace     Workspace?
  activities    ProjectActivity[]
}

model Subcontractor {
  id           String   @id @default(cuid())
  contractorId String
  name         String
  company      String?
  email        String?
  phone        String?
  specialty    String
  license      String?
  insurance    String?
  status       String   @default("active")
  rating       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contractor Contractor  @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  users      User[]
  quotes     Quote[]
  workspace  Workspace?
}

model Supplier {
  id           String   @id @default(cuid())
  contractorId String
  name         String
  email        String?
  phone        String?
  website      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contractor    Contractor    @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  priceSheets  PriceSheet[]
  materialItems MaterialItem[]
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String    @default("open")
  priority    String    @default("medium")
  dueDate     DateTime?
  completedAt DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, status])
}

model Note {
  id          String   @id @default(cuid())
  projectId   String?
  customerId  String?
  content     String
  type        String   @default("general")
  isAiGenerated Boolean @default(false)
  createdById String?
  createdAt   DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

model Inspection {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  summary     String
  findings    String
  photos      String?
  status      String   @default("scheduled")
  inspectedAt DateTime
  createdAt   DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

model Estimate {
  id                String    @id @default(cuid())
  contractorId      String
  customerId        String
  projectId         String?
  title             String
  amount            Float
  status            String    @default("draft")
  viewCount         Int       @default(0)
  closingProbability Float?
  lastViewedAt      DateTime?
  sentAt            DateTime?
  signedAt          DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project    Project?    @relation(fields: [projectId], references: [id])
  documents  Document[]
  followUps  FollowUp[]
  @@index([customerId])
  @@index([projectId])
}

model Quote {
  id              String   @id @default(cuid())
  projectId       String
  subcontractorId String
  title           String
  description     String?
  amount          Float
  status          String   @default("draft")
  validUntil      DateTime?
  lineItems       String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  @@index([projectId])
}

model FollowUp {
  id           String    @id @default(cuid())
  customerId   String
  estimateId   String?
  projectId    String?
  type         String    @default("call")
  reason       String
  status       String    @default("pending")
  dueDate      DateTime?
  completedAt  DateTime?
  isAiSuggested Boolean  @default(true)
  createdAt    DateTime  @default(now())
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  estimate Estimate? @relation(fields: [estimateId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])
  @@index([customerId, status])
}

model Document {
  id            String   @id @default(cuid())
  contractorId  String
  filename      String
  originalName  String
  mimeType      String
  size          Int
  filePath      String
  thumbnailPath String?
  fileType      String   @default("other")
  aiCategory    String?
  aiSummary     String?
  extractedData String?
  ocrText       String?
  extractionMethod String?  // pdf_text | pdf_ocr | pdf_hybrid | image_vision | text_direct | docx_text | csv_text
  // Collaborative extraction fields (v3)
  embeddedText         String?  // raw text from PDF text layer / TXT / DOCX / CSV
  visionText           String?  // raw text from OCR / vision provider
  extractionComparison String?  // JSON: per-method quality, agreement, key field presence
  extractionConfidence Float?   // 0-100 overall confidence
  missingDataFlags     String?  // JSON: { claimNumber, policyNumber, carrier, ... } → true if missing
  conflictFlags        String?  // JSON: { claimNumberMismatch, carrierMismatch, ... } → true if conflict
  status        String   @default("pending_review")
  customerId    String?
  projectId     String?
  estimateId    String?
  workspaceId   String?
  uploadedById  String?
  createdAt     DateTime @default(now())
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id])
  project    Project?   @relation(fields: [projectId], references: [id])
  estimate   Estimate?  @relation(fields: [estimateId], references: [id])
  workspace  Workspace? @relation(fields: [workspaceId], references: [id])
  uploadedBy User?      @relation("UploadedBy", fields: [uploadedById], references: [id])
  scopeAnalysis ScopeAnalysis[]
  @@index([contractorId, createdAt])
  @@index([projectId])
  @@index([workspaceId])
}

model PriceSheet {
  id            String   @id @default(cuid())
  contractorId  String
  supplierId    String?
  supplierName  String
  filename      String
  originalName  String
  filePath      String
  validFrom     DateTime?
  validUntil    DateTime?
  notes         String?
  extractedItems String?
  aiSummary     String?
  status        String   @default("processing")
  createdAt     DateTime @default(now())
  contractor    Contractor  @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])
  materialItems MaterialItem[]
  @@index([contractorId])
}

model MaterialItem {
  id           String   @id @default(cuid())
  contractorId String
  priceSheetId String?
  supplierId   String?
  name         String
  description  String?
  sku          String?
  category     String   @default("other")
  unit         String   @default("EA")
  unitCost     Float
  createdAt    DateTime @default(now())
  contractor Contractor  @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  priceSheet PriceSheet? @relation(fields: [priceSheetId], references: [id])
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
  @@index([contractorId])
  @@index([priceSheetId])
}

model Conversation {
  id           String   @id @default(cuid())
  contractorId String
  title        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  messages   Message[]
  @@index([contractorId, updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  contextType    String?
  contextData    String?
  attachments    String?
  actionResults  String?
  createdAt      DateTime @default(now())
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId, createdAt])
}

model Workspace {
  id              String   @id @default(cuid())
  contractorId    String
  name            String
  type            String
  description     String?
  color           String?
  status          String   @default("active")
  projectId       String?  @unique
  customerId      String?  @unique
  subcontractorId String?  @unique
  supplierId      String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contractor    Contractor      @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  project       Project?        @relation(fields: [projectId], references: [id])
  customer      Customer?       @relation(fields: [customerId], references: [id])
  subcontractor Subcontractor?  @relation(fields: [subcontractorId], references: [id])
  chats         WorkspaceChat[]
  members       WorkspaceMember[]
  memories      WorkspaceMemory[]
  actions       WorkspaceAction[]
  documents     Document[]
  @@index([contractorId, type])
}

model WorkspaceChat {
  id           String   @id @default(cuid())
  workspaceId  String
  chatType     String
  title        String
  visibility   String   @default("internal")
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  WorkspaceMessage[]
  @@index([workspaceId, chatType])
  @@unique([workspaceId, chatType])
}

model WorkspaceMessage {
  id            String   @id @default(cuid())
  chatId        String
  role          String
  content       String
  contextType   String?
  contextData   String?
  attachments   String?
  actionResults String?
  createdById   String?
  createdAt     DateTime @default(now())
  chat       WorkspaceChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdBy  User?         @relation("WorkspaceMessageCreator", fields: [createdById], references: [id])
  @@index([chatId, createdAt])
}

model WorkspaceMember {
  id           String   @id @default(cuid())
  workspaceId  String
  userId       String
  role         String   @default("member")
  permissions  String   @default("read,write")
  createdAt    DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([workspaceId, userId])
}

model WorkspaceMemory {
  id           String   @id @default(cuid())
  workspaceId  String
  category     String
  content      String
  metadata     String?
  source       String?  @default("ai")
  createdById  String?
  createdAt    DateTime @default(now())
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy  User?     @relation("MemoryCreator", fields: [createdById], references: [id])
  @@index([workspaceId, category])
  @@index([workspaceId, createdAt])
}

model WorkspaceAction {
  id           String   @id @default(cuid())
  workspaceId  String
  type         String
  status       String   @default("executed")
  detail       String
  payload      String
  sourceChatId String?
  createdAt    DateTime @default(now())
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  @@index([workspaceId, createdAt])
}

model ProjectActivity {
  id            String   @id @default(cuid())
  projectId     String
  contractorId  String
  userId        String?
  activityType  String
  title         String
  body          String?
  metadataJson  String?
  relatedId     String?
  relatedType   String?
  source        String   @default("user")
  createdAt     DateTime @default(now())
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor Contractor  @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([projectId, createdAt])
  @@index([contractorId, source])
}

// =============================================================================
// SCHEMA V2 — Production models: Auth, Multi-tenant, Memory, Agent Jobs, Audit
// =============================================================================

// --- Auth & API Keys --------------------------------------------------------

model ApiKey {
  id           String   @id @default(cuid())
  contractorId String
  userId       String?
  name         String   // e.g. "Production server", "Zapier integration"
  keyHash      String   @unique // SHA-256 of the actual key
  keyPrefix    String   // first 8 chars for identification
  scopes       String   @default("read,write") // comma-separated
  lastUsedAt   DateTime?
  lastUsedIp   String?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  user         User?       @relation("ApiKeyOwner", fields: [userId], references: [id], onDelete: SetNull)
  @@index([contractorId])
  @@index([keyHash])
}

model AuditLog {
  id           String   @id @default(cuid())
  contractorId String
  userId       String?
  actor        String   // user:email, api:prefix, system, ai
  action       String   // create, update, delete, login, export, ai_action
  resourceType String   // customer, project, document, message, etc.
  resourceId   String?
  detail       String?  // human-readable
  metadataJson String?  // structured changes
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  user         User?       @relation("AuditActor", fields: [userId], references: [id])
  @@index([contractorId, createdAt])
  @@index([contractorId, resourceType, resourceId])
  @@index([actor])
}

// --- Agent Jobs (DB-persisted, replaces in-memory Map) ----------------------

model AgentJob {
  id            String   @id @default(cuid())
  contractorId  String
  type          String   // chat, workspace_chat, doc_analysis, cron
  status        String   @default("queued") // queued, processing, done, error, cancelled
  priority      Int      @default(5) // 1 (high) to 10 (low)
  // Input
  inputJson     String   // JSON: message, conversationId, workspaceId, chatId, etc.
  // Output
  outputJson    String?  // JSON: text, actionResults, attachments
  // Progress
  heartbeat     String?
  thinkingJson  String?  // JSON array of thinking steps
  error         String?
  // Relations
  conversationId String?
  workspaceId    String?
  chatId         String?
  userId         String?
  // Timing
  startedAt    DateTime?
  completedAt  DateTime?
  expiresAt    DateTime?  // for queued job cleanup
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, status, priority, createdAt])
  @@index([contractorId, type, createdAt])
  @@index([status, expiresAt])
}

// --- Layered Memory System --------------------------------------------------

model CustomerMemory {
  id           String   @id @default(cuid())
  contractorId String
  customerId   String
  category     String   // preference, history, complaint, compliment, lifecycle, contact_note
  content      String
  source       String   @default("ai") // ai, user, system, import
  confidence   Float    @default(1.0)
  importance   Int      @default(5) // 1-10
  metadataJson String?
  embeddingId  String?  // FK to VectorEmbedding (future)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, customerId, category, createdAt])
  @@index([contractorId, category])
}

model ProjectMemory {
  id           String   @id @default(cuid())
  contractorId String
  projectId    String
  category     String   // decision, milestone, issue, material, schedule, financial, scope
  content      String
  source       String   @default("ai")
  importance   Int      @default(5)
  metadataJson String?
  embeddingId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, projectId, category, createdAt])
  @@index([contractorId, category])
}

model ContractorMemory {
  id           String   @id @default(cuid())
  contractorId String
  category     String   // policy, preference, pricing_rule, vendor_relation, lesson, default
  content      String
  source       String   @default("ai")
  metadataJson String?
  embeddingId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, category])
}

model AgentLesson {
  id           String   @id @default(cuid())
  contractorId String
  agentName    String   // orchestrator, estimator, dispatcher, claims, sales_coach
  lessonType   String   // success, failure, pattern, preference, correction
  trigger      String   // situation that triggered the lesson
  action       String   // what was done
  outcome      String   // what happened
  correction   String?  // what should be done next time
  metadataJson String?
  createdAt    DateTime @default(now())
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, agentName, lessonType])
  @@index([contractorId, createdAt])
}

model ConversationSummary {
  id             String   @id @default(cuid())
  contractorId   String
  conversationId String
  summary        String
  keyDecisions   String?  // JSON array
  actionItems    String?  // JSON array
  participants   String?  // JSON array
  tokenCount     Int?
  createdAt      DateTime @default(now())
  contractor     Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, conversationId])
  @@index([contractorId, createdAt])
}

// --- Knowledge Graph --------------------------------------------------------

model EntityRelation {
  id           String   @id @default(cuid())
  contractorId String
  sourceType   String   // customer, project, document, user, supplier, subcontractor, claim, material
  sourceId     String
  relationType String   // owns, works_on, references, supplied, employed_by, references_doc, etc.
  targetType   String
  targetId     String
  metadataJson String?
  confidence   Float    @default(1.0)
  createdAt    DateTime @default(now())
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@unique([sourceType, sourceId, relationType, targetType, targetId])
  @@index([contractorId, sourceType, sourceId])
  @@index([contractorId, targetType, targetId])
  @@index([contractorId, relationType])
}

// --- Vector Embeddings (for semantic search) --------------------------------

model VectorEmbedding {
  id           String   @id @default(cuid())
  contractorId String
  entityType   String   // customer_memory, project_memory, document, conversation, agent_lesson
  entityId     String
  chunkIndex   Int      @default(0)
  content      String
  embedding    String   // JSON array of floats (use pgvector in prod)
  model        String   @default("text-embedding-3-small")
  tokenCount   Int?
  createdAt    DateTime @default(now())
  @@unique([entityType, entityId, chunkIndex])
  @@index([contractorId, entityType, entityId])
  @@index([contractorId, model])
}

// --- Autonomy / Cron --------------------------------------------------------

model CronRun {
  id           String   @id @default(cuid())
  contractorId String
  jobName      String   // stalled_job_detector, daily_digest, lead_followup
  status       String   // running, success, error, skipped
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  itemsProcessed Int    @default(0)
  outputJson   String?
  error        String?
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, jobName, startedAt])
  @@index([jobName, status])
}

// --- SaaS Usage / Quotas ----------------------------------------------------

model UsageRecord {
  id           String   @id @default(cuid())
  contractorId String
  metric       String   // ai_messages, ai_tokens, uploads_bytes, tts_seconds, documents_analyzed
  count        Int      @default(1)
  bucket       DateTime // hour bucket (UTC)
  metadataJson String?
  createdAt    DateTime @default(now())
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@unique([contractorId, metric, bucket])
  @@index([contractorId, metric, bucket])
}

model AIUsageLog {
  id             String   @id @default(cuid())
  contractorId   String
  userId         String?
  customerId     String?
  projectId      String?
  documentId     String?
  purpose        String
  provider       String
  model          String
  inputTokens    Int?
  outputTokens   Int?
  totalTokens    Int?
  imageCount     Int      @default(0)
  webSearchCalls Int      @default(0)
  estimatedCost  Float?
  success        Boolean  @default(true)
  error          String?
  createdAt      DateTime @default(now())

  @@index([contractorId, createdAt])
  @@index([contractorId, purpose, createdAt])
  @@index([documentId])
}

// --- Onboarding Sessions (agent-driven) -------------------------------------

model OnboardingSession {
  id              String   @id @default(cuid())
  contractorId    String   @unique
  userId          String
  status          String   @default("in_progress") // in_progress, completed, abandoned
  // Conversation history for the onboarding agent
  messagesJson    String   @default("[]") // JSON array of { role, content, timestamp }
  // Detected/collected business intelligence
  businessProfile String?  // JSON: services, serviceAreas, companySize, roles, software, goals, specialties, processes
  // Research results from website/company enrichment
  researchJson    String?  // JSON: { website, description, services, location, social, reviews, teamSize }
  // Confidence score (0-100) — agent decides when to complete
  confidence      Int      @default(0)
  // Tracks which info categories have been covered
  coveredTopics   String   @default("[]") // JSON array of strings
  // The detected business type (roofing, restoration, public adjuster, etc.)
  businessType    String?  // roofing, restoration, public_adjuster, general_contractor, hvac, plumbing, other
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  updatedAt       DateTime @updatedAt
  contractor      Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  @@index([contractorId, status])
}


// --- Scope Management (line item selection + deductible pool) ----------------

model ScopeAnalysis {
  id            String   @id @default(cuid())
