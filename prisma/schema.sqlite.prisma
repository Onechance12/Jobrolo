  id              String   @id @default(cuid())
  contractorId    String
  sessionId       String?
  createdById     String?
  projectId       String?
  customerId      String?
  address         String?
  latitude        Float?
  longitude       Float?
  status          String   @default("new") // new, knocked, interested, follow_up, converted, not_interested, no_answer
  homeownerName   String?
  phone           String?
  notes           String?
  source          String   @default("field_copilot")
  metadataJson    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([contractorId, sessionId])
  @@index([contractorId, status])
  @@index([contractorId, projectId])
}

model CanvassingActivity {
  id              String   @id @default(cuid())
  contractorId    String
  sessionId       String?
  leadId          String?
  userId          String?
  type            String   // knock, photo, note, no_answer, interested, follow_up, converted
  summary         String
  latitude        Float?
  longitude       Float?
  metadataJson    String?
  createdAt       DateTime @default(now())
  @@index([contractorId, sessionId])
  @@index([contractorId, leadId])
  @@index([contractorId, userId, createdAt])
}

// =============================================================================
// PHASE 11.2 — PROPERTY MEMORY / CANVASSING INTELLIGENCE
// =============================================================================
// Not every house is a lead or customer. These models let Jobrolo remember
// property-level canvassing history, roof observations, door attempts, street
// coverage, and rep game plans without forcing every door into the CRM pipeline.
// Keep this property/workflow based; avoid sensitive personal profiling.

model PropertyMemory {
  id                 String   @id @default(cuid())
  contractorId       String
  createdById        String?
  primaryLeadId      String?
  customerId         String?
  projectId          String?
  address            String?
  normalizedAddress  String?
  city               String?
  state              String?
  postalCode         String?
  ownerName          String?
  ownerMailingAddress String?
  parcelId           String?
  countyAccountId    String?
  marketValue        Float?
  assessedValue      Float?
  improvementValue   Float?
  landValue          Float?
  livingAreaSqft     Int?
  yearBuilt          Int?
  bedrooms           Float?
  bathrooms          Float?
  stories            Float?
  ownerOccupiedSignal String?
  lastEnrichedAt     DateTime?
  enrichmentStatus   String?  // never_researched, cached, provider, imported, needs_review
  latitude           Float?
  longitude          Float?
  propertyType       String?  // single_family, townhome, condo, commercial, unknown
  occupancyStatus    String   @default("unknown") // owner_occupied, renter, vacant, unknown
  solicitationStatus String   @default("ok") // ok, no_soliciting, do_not_knock, gated, unsafe, unknown
  roofCondition      String   @default("unknown") // unknown, new, good, aged, damaged, tarped, missing_shingles
  roofAgeSignal      String?
  damageSignal       String?
  opportunityScore   Int      @default(0)
  priority           String   @default("normal") // low, normal, high, hot
  status             String   @default("watch") // watch, prospect, follow_up, do_not_contact, converted, not_fit
  lastObservedAt     DateTime?
  lastKnockedAt      DateTime?
  nextFollowUpAt     DateTime?
  summary            String?
  notes              String?
  tagsJson           String?
  dataSourceJson     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@index([contractorId, normalizedAddress])
  @@index([contractorId, status, priority])
  @@index([contractorId, primaryLeadId])
  @@index([contractorId, projectId])
  @@index([contractorId, lastObservedAt])
  @@index([contractorId, nextFollowUpAt])
}

model PropertyObservation {
  id                String   @id @default(cuid())
  contractorId      String
  propertyMemoryId  String
  canvassingLeadId  String?
  sessionId         String?
  userId            String?
  type              String   // roof_condition, damage_observation, no_soliciting, renter, new_roof, missing_shingles, note, photo
  title             String
  summary           String?
  roofCondition     String?
  damageSignal      String?
  severity          String?  // low, moderate, high, unknown
  confidence        Float?
  photoDocumentId   String?
  latitude          Float?
  longitude         Float?
  observedAt        DateTime @default(now())
  metadataJson      String?
  createdAt         DateTime @default(now())
  @@index([contractorId, propertyMemoryId, observedAt])
  @@index([contractorId, canvassingLeadId])
  @@index([contractorId, type])
}

model DoorAttempt {
  id                String   @id @default(cuid())
  contractorId      String
  propertyMemoryId  String
  canvassingLeadId  String?
  sessionId         String?
  userId            String?
  outcome           String   // knocked, no_answer, spoke, interested, inspection_set, follow_up, not_interested, renter, no_soliciting, do_not_knock
  contactName       String?
  contactRole       String?  // homeowner, renter, neighbor, unknown
  summary           String?
  scriptUsed        String?
  objection         String?
  nextStep          String?
  followUpAt        DateTime?
  latitude          Float?
  longitude         Float?
  metadataJson      String?
  createdAt         DateTime @default(now())
  @@index([contractorId, propertyMemoryId, createdAt])
  @@index([contractorId, canvassingLeadId])
  @@index([contractorId, userId, createdAt])
  @@index([contractorId, outcome])
}

model StreetMemory {
  id                String   @id @default(cuid())
  contractorId      String
  territoryName     String?
  streetName        String
  city              String?
  state             String?
  lastWorkedAt      DateTime?
  lastWorkedById    String?
  totalDoors        Int      @default(0)
  totalAttempts     Int      @default(0)
  conversations     Int      @default(0)
  inspectionsSet    Int      @default(0)
  noAnswers         Int      @default(0)
  doNotKnockCount   Int      @default(0)
  notes             String?
  tagsJson          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@index([contractorId, streetName, city, state])
  @@index([contractorId, territoryName])
  @@index([contractorId, lastWorkedAt])
}

model CanvassingGamePlan {
  id                  String   @id @default(cuid())
  contractorId        String
  userId              String?
  sessionId           String?
  title               String
  territoryName       String?
  focusMode           String   @default("partner_choice") // fresh_hail, follow_ups, higher_value, easy_conversations, old_damage, close_to_current_jobs
  energyLevel         String?  // low, medium, high, warmup
  customerFocus       String?  // property/workflow based opportunity focus, not protected-class profiling
  timeBudgetMinutes   Int?
  goalDoors           Int?
  goalConversations   Int?
  goalInspections     Int?
  status              String   @default("draft") // draft, active, completed, archived
  strategySummary     String?
  recommendedStart    String?
  avoidNotes          String?
  scriptSuggestion    String?
  kpiSnapshotJson     String?
  recommendationsJson String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@index([contractorId, userId, status])
  @@index([contractorId, sessionId])
  @@index([contractorId, territoryName])
}
// =============================================================================
// PHASE 11.3 — ACTIVE PROPERTY RESEARCH / STREET GAME PLANNER
// =============================================================================
// These models separate messy on-demand research from long-term PropertyMemory.
// A research run can pull cached memories, imported rows, external property APIs,
// and user-provided GPS/street context. Candidates must be confirmed before they
// become authoritative property memory. Keep all targeting property/workflow based.

model PropertyResearchRun {
  id                   String   @id @default(cuid())
  contractorId         String
  userId               String?
  mode                 String   @default("approaching_house") // approaching_house, address_lookup, street_game_plan, neighborhood_research
  status               String   @default("draft") // draft, researching, needs_confirmation, confirmed, failed, archived
  query                String?
  requestedAddress     String?
  normalizedAddress    String?
  streetNamesJson      String?
  city                 String?
  state                String?
  postalCode           String?
  latitude             Float?
  longitude            Float?
  accuracyMeters       Float?
  focusMode            String?
  energyLevel          String?
  mindset              String?
  timeBudgetMinutes    Int?
  goalDoors            Int?
  goalConversations    Int?
  goalInspections      Int?
  resultSummary        String?
  confidence           Float?
  selectedCandidateId  String?
  createdMemoryId      String?
  providerSummaryJson  String?
  metadataJson         String?
  error                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([contractorId, userId, status])
  @@index([contractorId, mode, createdAt])
  @@index([contractorId, normalizedAddress])
}

model PropertyResearchCandidate {
  id                   String   @id @default(cuid())
  contractorId         String
  researchRunId        String
  propertyMemoryId     String?
  address              String?
  normalizedAddress    String?
  city                 String?
  state                String?
  postalCode           String?
  ownerName            String?
  ownerMailingAddress  String?
  parcelId             String?
  countyAccountId      String?
  source               String   @default("jobrolo") // property_memory, imported_data, provider, manual, inferred
  confidence           Float    @default(0)
  matchReason          String?
  latitude             Float?
  longitude            Float?
  propertyType         String?
  marketValue          Float?
  assessedValue        Float?
  improvementValue     Float?
  landValue            Float?
  livingAreaSqft       Int?
  yearBuilt            Int?
  bedrooms             Float?
  bathrooms            Float?
  stories              Float?
  ownerOccupiedSignal  String?  // likely_owner_occupied, likely_rental, unknown
  roofOpportunityScore Int      @default(0)
  stormExposureScore   Int      @default(0)
  followUpScore        Int      @default(0)
  overallScore         Int      @default(0)
  status               String   @default("candidate") // candidate, selected, rejected, saved
  rawJson              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([contractorId, researchRunId])
  @@index([contractorId, normalizedAddress])
  @@index([contractorId, overallScore])
}

model PropertyEnrichmentSnapshot {
  id                   String   @id @default(cuid())
  contractorId         String
  researchRunId        String?
  candidateId          String?
  propertyMemoryId     String?
  source               String
  sourceLabel          String?
  sourceUrl            String?
  address              String?
  normalizedAddress    String?
  ownerName            String?
  ownerMailingAddress  String?
  parcelId             String?
  countyAccountId      String?
  propertyType         String?
  marketValue          Float?
  assessedValue        Float?
  improvementValue     Float?
  landValue            Float?
  livingAreaSqft       Int?
  yearBuilt            Int?
  bedrooms             Float?
  bathrooms            Float?
  stories              Float?
  ownerOccupiedSignal  String?
  confidence           Float    @default(0)
  rawJson              String?
  capturedAt           DateTime @default(now())
  expiresAt            DateTime?
  @@index([contractorId, propertyMemoryId])
  @@index([contractorId, normalizedAddress])
  @@index([contractorId, source, capturedAt])
}

model StreetResearchRun {
  id                   String   @id @default(cuid())
  contractorId         String
  userId               String?
  status               String   @default("draft") // draft, researched, active, completed, archived
  title                String
  streetNamesJson      String
  city                 String?
  state                String?
  postalCode           String?
  focusMode            String   @default("partner_choice")
  energyLevel          String?
  mindset              String?
  timeBudgetMinutes    Int?
  goalDoors            Int?
  goalConversations    Int?
  goalInspections      Int?
  summary              String?
  recommendedStart     String?
  avoidNotes           String?
  scriptSuggestion     String?
  candidateSummaryJson String?
  createdGamePlanId    String?
  metadataJson         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@index([contractorId, userId, status])
  @@index([contractorId, focusMode])
}
